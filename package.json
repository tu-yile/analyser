{
  "name": "analyser",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "imports": {
    "#src/*": {
      "types": "./src/*",
      "default": "./dist/src/*"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "gateway": "npm run build --silent && node dist/src/gateway/index.js",
    "gateway:start": "npm run build --silent && bash scripts/lark_gateway_daemon.sh start",
    "gateway:stop": "bash scripts/lark_gateway_daemon.sh stop",
    "gateway:status": "bash scripts/lark_gateway_daemon.sh status",
    "send:lark": "npm run build --silent && node dist/scripts/send_lark_report.js"
  },
  "dependencies": {
    "@larksuite/cli": "^1.0.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  }
}
